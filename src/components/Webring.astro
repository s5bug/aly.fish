---
import { Picture } from 'astro:assets'
import webringData from 'webring:data'
import { colord, extend } from 'colord'
import labPlugin from 'colord/plugins/lab'
import { TSPSolverNN } from 'tsp-solver-nn'

extend([labPlugin])

let formatAlt: (s: string) => string
switch (Astro.currentLocale) {
  case 'ja':
    formatAlt = (s: string) => `${s}の88x31`
    break
  case 'en':
    formatAlt = (s: string) => `88x31 for ${s}`
    break
}

const distanceMatrix: number[][] = new Array(webringData.length)
for (let i = 0; i < distanceMatrix.length; i++) {
  distanceMatrix[i] = new Array(webringData.length).fill(0)
}

for (let i = 0; i < distanceMatrix.length; i++) {
  const rgbI = webringData[i].vibrantColorRgb
  const labI = colord({ r: rgbI[0], g: rgbI[1], b: rgbI[2] }).toLab()
  for (let j = i + 1; j < distanceMatrix.length; j++) {
    const rgbJ = webringData[j].vibrantColorRgb
    const labJ = colord({ r: rgbJ[0], g: rgbJ[1], b: rgbJ[2] }).toLab()

    const dl = labJ.l - labI.l
    const da = labJ.a - labI.a
    const db = labJ.b - labI.b
    const distSq = dl * dl + da * da + db * db
    const dist = Math.sqrt(distSq)

    distanceMatrix[i][j] = dist
    distanceMatrix[j][i] = dist
  }
}

const tspSolver = new TSPSolverNN()
const path = tspSolver.getPath(distanceMatrix)

const sortedWebringData = path.route.map((idx) => webringData[idx])
---

<p>
{sortedWebringData.map(e =>
  <a href={e.site.toString()} style={`background: rgb(${e.vibrantColorRgb[0]}, ${e.vibrantColorRgb[1]}, ${e.vibrantColorRgb[2]});`}>
    <Picture src={e.localPath} alt={formatAlt(e.site.toString())} width={88} height={31} />
  </a>
)}
</p>

<style>
  p {
    line-height: 0;
    image-rendering: optimizeSpeed;
    image-rendering: -moz-crisp-edges;
    image-rendering: -o-crisp-edges;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: optimize-contrast;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  a {
    display: inline-block;
    width: 88px;
    height: 31px;
  }
</style>
