{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alyfish",
  "routes": [
    {
      "pattern": "aly.fish",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2026-03-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true,
    "traces": {
      "enabled": true
    }
  }
}
