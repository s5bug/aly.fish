{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alyfish",
  "routes": [
    {
      "pattern": "aly.fish",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2026-03-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "18c7b4a2cb4a41bbb98b361ecd5ee81f"
    }
  ]
}
